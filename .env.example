# ===========================================
# Weather App - Variables de Entorno
# ===========================================
# Copia este archivo como .env.local y agrega tus API keys
# 
# NUNCA subas el archivo .env.local a GitHub
# ===========================================

# OpenWeatherMap API Key
# Obtén tu key gratis en: https://openweathermap.org/api
# Para demo sin API key, la app mostrará datos limitados
VITE_WEATHER_API_KEY=tu_api_key_de_openweathermap_aqui

# Unsplash API Key (para imágenes de fondo)
# Obtén tu key gratis en: https://unsplash.com/developers
# Para demo sin API key, usará imágenes por defecto
VITE_UNSPLASH_API_KEY=tu_api_key_de_unsplash_aqui
